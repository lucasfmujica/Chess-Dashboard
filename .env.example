# Environment Variables Example
# Copy this file to .env.local for local development

# Application Configuration
REACT_APP_NAME=Chess Dashboard
REACT_APP_VERSION=1.0.0
REACT_APP_ENV=development

# API Configuration (for future use)
# REACT_APP_API_URL=http://localhost:3001/api
# REACT_APP_API_TIMEOUT=30000

# Feature Flags
REACT_APP_ENABLE_LICHESS_SYNC=true
REACT_APP_ENABLE_ANALYTICS=false
REACT_APP_ENABLE_DEBUG_MODE=false

# Lichess API (when implemented)
# REACT_APP_LICHESS_CLIENT_ID=your_client_id_here
# REACT_APP_LICHESS_REDIRECT_URI=http://localhost:3000/callback

# Storage Configuration
REACT_APP_STORAGE_PREFIX=chess-dashboard
REACT_APP_MAX_STORAGE_SIZE=10485760

# Performance Monitoring (optional)
# REACT_APP_SENTRY_DSN=
# REACT_APP_ENABLE_PERFORMANCE_MONITORING=false

# Analytics (optional)
# REACT_APP_GA_TRACKING_ID=
# REACT_APP_POSTHOG_KEY=

# Development Tools
REACT_APP_ENABLE_REDUX_DEVTOOLS=false
REACT_APP_SHOW_COMPONENT_NAMES=true
