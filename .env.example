# Environment Variables Example
# Copy this file to .env.local for local development
# NOTE: Vite only exposes variables prefixed with VITE_ to the app.

# Application Configuration
VITE_APP_NAME=Chess Dashboard
VITE_APP_VERSION=1.0.0
VITE_APP_ENV=development

# API Configuration (for future use)
# VITE_API_URL=http://localhost:3001/api
# VITE_API_TIMEOUT=30000

# Feature Flags
VITE_ENABLE_LICHESS_SYNC=true
VITE_ENABLE_ANALYTICS=false
VITE_ENABLE_DEBUG_MODE=false

# Lichess API (when implemented)
# VITE_LICHESS_CLIENT_ID=your_client_id_here
# VITE_LICHESS_REDIRECT_URI=http://localhost:3000/callback

# Lichess opening explorer (server-only, used by api/explorer.ts).
# Lichess requires an OAuth2 token now (no scope needed) — generate a
# personal access token at https://lichess.org/account/oauth/token
# LICHESS_TOKEN=your_personal_access_token_here

# Storage Configuration
VITE_STORAGE_PREFIX=chess-dashboard
VITE_MAX_STORAGE_SIZE=10485760

# Performance Monitoring (optional)
# VITE_SENTRY_DSN=
# VITE_ENABLE_PERFORMANCE_MONITORING=false

# Analytics (optional)
# VITE_GA_TRACKING_ID=
# VITE_POSTHOG_KEY=

# Development Tools
VITE_SHOW_COMPONENT_NAMES=true
